---
import Logo from './Logo.astro'
import { withBase } from '../lib/url.ts'
---

<header
  class="sticky top-0 z-40 border-b border-border bg-elevated backdrop-blur-md"
>
  <div class="mx-auto flex h-14 max-w-[1400px] items-center gap-6 px-5">
    <a
      href={withBase('/')}
      class="flex items-center gap-2.5 text-fg-1 transition-opacity hover:opacity-80"
    >
      <Logo size={18} />
      <span class="text-[0.9375rem] font-semibold tracking-tight">chromatrix</span>
    </a>

    <nav class="flex items-center gap-5 text-sm text-fg-3">
      <a href={withBase('/docs/introduction')} class="transition-colors hover:text-fg-1">Docs</a>
      <a
        href="https://www.npmjs.com/org/chromatrix"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-fg-1">npm</a
      >
    </nav>

    <div class="ml-auto flex items-center gap-1">
      <a
        href="https://github.com/tobiasstrebitzer/chromatrix"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="chromatrix on GitHub"
        class="flex size-8 items-center justify-center rounded-md text-fg-3 transition-colors hover:bg-surface-hover hover:text-fg-1"
      >
        <svg width="17" height="17" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
      </a>

      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        class="flex size-8 cursor-pointer items-center justify-center rounded-md text-fg-3 transition-colors hover:bg-surface-hover hover:text-fg-1"
      >
        <!-- sun (shown in dark mode) -->
        <svg
          class="hidden dark:block"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path>
        </svg>
        <!-- moon (shown in light mode) -->
        <svg
          class="dark:hidden"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark'
    root.dataset.theme = next
    localStorage.setItem('cx-docs-theme', next)
  })
</script>
