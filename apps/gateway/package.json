{
  "name": "@chromatrix/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "chromatrix gateway (NestJS + @silkweave/nestjs): raw-WS CDP mux mounted at the underlying http.Server (outside Nest's pipeline) + silkweave mgmt/MCP Actions (provision/allocate/health/takeover). Built after S1; see docs/PRD.md §6.",
  "scripts": {
    "dev": "VITE_DEV_URL=http://localhost:5181 node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/main.ts",
    "start": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/main.ts",
    "accept": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/e2e/acceptance.ts",
    "e2e": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/e2e/multi-session.ts",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@chromatrix/cdp": "workspace:*",
    "@chromatrix/core": "workspace:*",
    "@chromatrix/fidelity": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@silkweave/mcp": "^4.2.0",
    "@silkweave/nestjs": "^4.2.0",
    "@silkweave/trpc": "^4.2.0",
    "@silkweave/typegen": "^4.2.0",
    "@trpc/server": "^11.7.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "http-proxy-middleware": "^3.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13"
  }
}
