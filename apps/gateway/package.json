{
  "name": "@chromatrix/gateway",
  "version": "0.1.1",
  "type": "module",
  "description": "chromatrix gateway (NestJS + @silkweave/nestjs): raw-WS CDP mux mounted at the underlying http.Server (outside Nest's pipeline) + silkweave mgmt/MCP Actions (provision/allocate/health/takeover) + the bundled dashboard. Run it with `npx @chromatrix/gateway`.",
  "keywords": [
    "chromatrix",
    "chrome-devtools-protocol",
    "cdp",
    "gateway",
    "mcp",
    "browser-automation"
  ],
  "license": "MIT",
  "author": "Tobias Strebitzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasstrebitzer/chromatrix.git",
    "directory": "apps/gateway"
  },
  "homepage": "https://github.com/tobiasstrebitzer/chromatrix/tree/master/apps/gateway#readme",
  "bugs": "https://github.com/tobiasstrebitzer/chromatrix/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chromatrix-gateway": "./build/main.mjs"
  },
  "files": [
    "build",
    "web"
  ],
  "scripts": {
    "dev": "VITE_DEV_URL=http://localhost:5181 node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/main.ts",
    "start": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/main.ts",
    "accept": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/e2e/acceptance.ts",
    "e2e": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/e2e/multi-session.ts",
    "clean": "rimraf build web",
    "build": "tsdown",
    "bundle-web": "pnpm --filter @chromatrix/web run build && rimraf web && cp -R ../web/dist ./web",
    "prepack": "pnpm clean && pnpm build && pnpm bundle-web",
    "typecheck": "tsgo -p tsconfig.json",
    "pw": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/e2e/playwright.ts",
    "takeover": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/e2e/takeover-input.ts"
  },
  "dependencies": {
    "@chromatrix/cdp": "workspace:*",
    "@chromatrix/core": "workspace:*",
    "@chromatrix/fidelity": "workspace:*",
    "@chromatrix/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@silkweave/mcp": "^4.4.0",
    "@silkweave/nestjs": "^4.4.0",
    "@silkweave/trpc": "^4.4.0",
    "@silkweave/typegen": "^4.4.0",
    "@trpc/server": "^11.7.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "playwright-core": "^1.49.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "unplugin-swc": "^1.5.8"
  }
}
