{
  "name": "@chromatrix/cli",
  "version": "0.1.1",
  "type": "module",
  "description": "chromatrix CLI - a thin remote client over the gateway's MCP surface (@silkweave/mcp cliProxy). Every @Mcp tool the gateway exposes becomes a command automatically; there is no per-command code here by design.",
  "keywords": [
    "chromatrix",
    "cli",
    "chrome-devtools-protocol",
    "mcp"
  ],
  "license": "MIT",
  "author": "Tobias Strebitzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasstrebitzer/chromatrix.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/tobiasstrebitzer/chromatrix/tree/master/apps/cli#readme",
  "bugs": "https://github.com/tobiasstrebitzer/chromatrix/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chromatrix": "./build/index.mjs"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "start": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/index.ts",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@chromatrix/shared": "workspace:*",
    "@silkweave/core": "^4.4.0",
    "@silkweave/mcp": "^4.4.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/node": "^22.10.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10"
  }
}
