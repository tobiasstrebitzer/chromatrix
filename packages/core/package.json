{
  "name": "@chromatrix/core",
  "version": "0.1.1",
  "type": "module",
  "description": "Domain core for chromatrix: identity registry, session/tab-pool orchestration, single-writer profile locking, health checks, and the orphaned-Chrome-tree reaper. Consumed by apps/gateway. Populated after S1/S3.",
  "keywords": [
    "chrome",
    "browser-automation",
    "chrome-devtools-protocol",
    "orchestration"
  ],
  "license": "MIT",
  "author": "Tobias Strebitzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasstrebitzer/chromatrix.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tobiasstrebitzer/chromatrix/tree/master/packages/core#readme",
  "bugs": "https://github.com/tobiasstrebitzer/chromatrix/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "@chromatrix/source": "./src/index.ts",
      "types": "./build/index.d.mts",
      "default": "./build/index.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsgo -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@chromatrix/cdp": "workspace:*",
    "@chromatrix/fidelity": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "vitest": "^3.2.0"
  }
}
