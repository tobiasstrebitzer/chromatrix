{
  "name": "@chromatrix/cdp",
  "version": "0.1.0",
  "type": "module",
  "description": "CDP client + flat-session multiplexer for chromatrix: one upstream connection to Chrome, N downstream clients, per-client command-id remapping, event routing by sessionId, per-tab ACLs, and a pluggable message-interception layer (the mitigating-mux core). Proven in spike S1 (now retired) and promoted here.",
  "keywords": ["chrome-devtools-protocol", "cdp", "chrome", "browser-automation", "multiplexer"],
  "license": "MIT",
  "author": "Tobias Strebitzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobiasstrebitzer/chromatrix.git",
    "directory": "packages/cdp"
  },
  "homepage": "https://github.com/tobiasstrebitzer/chromatrix/tree/master/packages/cdp#readme",
  "bugs": "https://github.com/tobiasstrebitzer/chromatrix/issues",
  "publishConfig": { "access": "public" },
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "files": ["build"],
  "exports": {
    ".": {
      "@chromatrix/source": "./src/index.ts",
      "types": "./build/index.d.mts",
      "default": "./build/index.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "typecheck": "tsgo -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "vitest": "^3.2.0"
  }
}
