{
  "name": "@chromatrix/fidelity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-fidelity layer for chromatrix: Chrome launch flags, CDP leak-mitigation policies (Runtime.enable suppression + isolated-world emulation), fingerprint hygiene, and verification probes (Runtime.enable getter-trap, WebGL renderer assertions) run by `pnpm fidelity:check`. Proven in spikes S1/S2 (now retired) and promoted here.",
  "main": "./build/index.mjs",
  "types": "./build/index.d.mts",
  "files": ["build"],
  "exports": {
    ".": {
      "@chromatrix/source": "./src/index.ts",
      "types": "./build/index.d.mts",
      "default": "./build/index.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "check": "node --conditions=@chromatrix/source --import @swc-node/register/esm-register src/eval.ts",
    "typecheck": "tsgo -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@chromatrix/cdp": "workspace:*"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/node": "^22.10.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "vitest": "^3.2.0"
  }
}
